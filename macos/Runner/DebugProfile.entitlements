<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- App Sandbox DISABLED. As a Developer-ID (non-App-Store) app, AutoSub
	     launches the engine as a child process (it spawns ffmpeg + the local LLM
	     server) and reads the user's media. macOS attributes that file access to
	     AutoSub, so the standard "would like to access your Downloads folder"
	     prompt covers the engine too — no sandbox bookmarks / Full Disk Access
	     needed. (App Store eligibility would require re-sandboxing + in-process
	     libav; deferred.) -->
	<key>com.apple.security.app-sandbox</key>
	<false/>
	<key>com.apple.security.cs.allow-jit</key>
	<true/>
</dict>
</plist>
